{
  "name": "istio-pulumi",
  "version": "0.1.0",
  "description": "Pulumi TypeScript bindings for Istio CRDs.",
  "license": "MIT AND Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masonbrothers/istio-pulumi.git"
  },
  "bugs": {
    "url": "https://github.com/masonbrothers/istio-pulumi/issues"
  },
  "homepage": "https://github.com/masonbrothers/istio-pulumi#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "pnpm@10.7.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "crds",
    "dist",
    "LICENSE.md",
    "README.md",
    "crd2pulumi.config.mjs",
    "THIRD_PARTY_LICENSES",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "generate:crds": "generate-crd2pulumi-package",
    "test": "vitest run",
    "test:dist": "node test/dist-smoke.cjs",
    "test:kind": "smoke-crd2pulumi-kubernetes",
    "test:pack": "smoke-crd2pulumi-package",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/types/index.js",
      "import": "./dist/types/index.js"
    }
  },
  "peerDependencies": {
    "@pulumi/kubernetes": ">=4.18.0 <6",
    "@pulumi/pulumi": ">=3.144.0 <5"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "crd2pulumi-package-tools": "github:masonbrothers/crd2pulumi-package-tools#d82813ab4e8def5e1aa04085be7832f5bd628246",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}

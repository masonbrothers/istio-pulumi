{
  "compilerOptions": {
    "declaration": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "*.ts",
    "*/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test",
    "vitest.config.ts"
  ]
}
